{
    "version": 6,
    "configurePresets": [
        {
            "name": "debug",
            "displayName": "Debug",
            "generator": "Visual Studio 18 2026",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_SYSTEM_VERSION": "10.0.19041.0",
                "BUILD_TESTING": "ON"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "generator": "Visual Studio 18 2026",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_SYSTEM_VERSION": "10.0.19041.0",
                "BUILD_TESTING": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Build Debug",
            "configurePreset": "debug",
            "configuration": "Debug"
        },
        {
            "name": "release",
            "displayName": "Build Release",
            "configurePreset": "release",
            "configuration": "Release"
        }
    ],
    "packagePresets": [
        {
            "name": "debug",
            "displayName": "Package Debug",
            "configurePreset": "debug",
            "configurations": ["Debug"]
        },
        {
            "name": "release",
            "displayName": "Package Release",
            "configurePreset": "release",
            "configurations": ["Release"]
        }
    ],
    "testPresets": [
        {
            "name": "debug",
            "displayName": "Test Debug",
            "configurePreset": "debug",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "release",
            "displayName": "Test Release",
            "configurePreset": "release",
            "configuration": "Release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "debug-verbose",
            "displayName": "Test Debug (Verbose)",
            "configurePreset": "debug",
            "configuration": "Debug",
            "output": {
                "verbosity": "extra",
                "outputOnFailure": true
            }
        },
        {
            "name": "release-verbose",
            "displayName": "Test Release (Verbose)",
            "configurePreset": "release",
            "configuration": "Release",
            "output": {
                "verbosity": "extra",
                "outputOnFailure": true
            }
        }
    ]
}
